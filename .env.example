NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Canonical site origin used to build magic-link redirect URLs (avoids
# trusting the request Host header). Falls back to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=
# Bearer token the cron Route Handlers require in `Authorization: Bearer <token>`.
CRON_SECRET=
# Resend API key for transactional reminder emails.
RESEND_API_KEY=
# FR18 (docs/PRD.md §4.3): Web Push (VAPID). Generate a pair with
# `npx web-push generate-vapid-keys`. The NEXT_PUBLIC_ variant is the same
# public key, exposed to the browser to open a push subscription.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
# FR10 (docs/PRD.md §1.6, Phase 2): API key for the source-watcher's structured
# extraction. Free-tier is sufficient at MVP scale. Read only server-side
# (lib/groq/client.ts); never exposed to the browser.
GROQ_API_KEY=
# Optional: override the model if the free-tier catalog changes
# (defaults to openai/gpt-oss-120b). See lib/source-watcher/config.ts.
GROQ_EXTRACTION_MODEL=
#
# --- Alternative provider (any OpenAI-compatible endpoint) --------------------
# Leave the three vars below blank to stay on Groq. To use a free-tier
# alternative instead, set all three. Example — Google Gemini (AI Studio):
#   LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   LLM_API_KEY=<your Gemini API key>
#   LLM_MODEL=gemini-2.0-flash
# LLM_API_KEY takes precedence over GROQ_API_KEY; LLM_MODEL over GROQ_EXTRACTION_MODEL.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
