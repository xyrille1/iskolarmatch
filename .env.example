NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Canonical site origin used to build magic-link redirect URLs (avoids
# trusting the request Host header). Falls back to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=
# Bearer token the cron Route Handlers require in `Authorization: Bearer <token>`.
CRON_SECRET=
# Resend API key for transactional reminder emails.
RESEND_API_KEY=
# FR18 (docs/PRD.md §4.3): Web Push (VAPID). Generate a pair with
# `npx web-push generate-vapid-keys`. The NEXT_PUBLIC_ variant is the same
# public key, exposed to the browser to open a push subscription.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
